[k3s_servers]
%{ for name, n in servers ~}
${name} ansible_host=${n.ip}
%{ endfor ~}

[k3s_agents]
%{ for name, n in agents ~}
${name} ansible_host=${n.ip}
%{ endfor ~}

[k3s_cluster:children]
k3s_servers
k3s_agents

[k3s_cluster:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=~/.ssh/homelab
ansible_python_interpreter=/usr/bin/python3